# ─────────────────────────────────────────────────────────────────────────────
# NBA Props Research Tool — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Tesseract OCR binary path (Windows — adjust to your install location)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── Database ─────────────────────────────────────────────────────────────────
# Path to the DuckDB file, relative to the project root.
DB_PATH=data/nba_props.duckdb

# ── Models ───────────────────────────────────────────────────────────────────
# Directory where trained model .pkl files are saved/loaded from.
MODELS_DIR=models

# Set to true to always retrain models even if .pkl files already exist.
FORCE_RETRAIN=false

# ── Bankroll settings ─────────────────────────────────────────────────────────
# Your total betting bankroll in dollars.  Used only for Kelly sizing display.
BANKROLL=1000

# Max Kelly fraction to bet on any single prop (as a decimal, e.g. 0.05 = 5%).
MAX_KELLY_FRACTION=0.05

# ── EV filter ────────────────────────────────────────────────────────────────
# Minimum EV percentage (as a decimal) required to include a prop in the
# output ranking.  0.03 = 3% EV.
EV_THRESHOLD=0.03

# ── Data / seasons ───────────────────────────────────────────────────────────
# Comma-separated list of NBA seasons to ingest historical data for.
# Format: YYYY-YY  (e.g. 2024-25 for the 2024-2025 season)
SEASONS=2022-23,2023-24,2024-25

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path for log file output.
LOG_FILE=logs/nba_props.log
